{"mappings":"AAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiHA;;;;;AASA;;;;AAaA;;;;;;;;;;AAeA;;;;;AASA;;;;;;AAQA;;;;AAMA;;;;;AAYA;;;;;AAOA;;;;AAUA;;;;;;;AAYA;;;;AAMA;;;;;;;AAQA;;;;AAIA;;;;AAQA;;;;;;AAUA;;;;;;;;;;;;;AAmBA;;;;AAQA;;;;;;AAWA;;;;AAMA;;;;AAMA;;;;AAMA;;;;AAAA;;;;AAQA;;;;;AAOA;;;;AAOA;;;;;AAOA;;;;AAMA;;;;AAgBA;;;;;AAKA;;;;AAIA;;;;;;AAUA;;;;AAMA;;;;AAOA;;;;;AAQA;;;;AAOA;;;;AAQA;;;;;AAcA;;;;;AAMA;;;;AAIA;;;;AAIA;;;;;;;;;;;;AAYA;;;;;;AAMA;;;;;AAUA;;;;;;;;;AASA;EAEE;;;;;;AAMF;;;;;;;;AAQA;EAEE;;;;;;AAMF;;;;;;;;AAQA;EAEE;;;;;;AAMF;;;;;;;;AAWA;;;;AAIA;;;;;AAKA;;;;;AAKA;;;;;;AAMA;;;;;AAKA;;;;;;AAMA;;;;AAIA;;;;;AAKA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;AAIA;;;;;AAKA;;;;;AAKA;;;;;AAKA;;;;;AAKA;;;;;AAKA;;;;;AAKA;;;;;AAKA;EAEE;;;;EAIA;;;;EAIA;;;;EAIA;;;;;;AAMF;EAEE","sources":["css/styles.css"],"sourcesContent":["@tailwind base;\r\n@tailwind components;\r\n@tailwind utilities;\r\n\r\n@layer base {\r\n    html {\r\n        @apply min-h-screen;\r\n    }\r\n    :where(button, a, input, textarea, select):focus-visible {\r\n        @apply outline-none ring-2 ring-accentBlue dark:ring-gray-500 ring-offset-2 ring-offset-accentCyan dark:ring-offset-white;\r\n    }\r\n\r\n    h1,\r\n    h2,\r\n    h3,\r\n    h4,\r\n    h5,\r\n    h6 {\r\n        @apply font-bold capitalize;\r\n    }\r\n    h1 {\r\n        @apply mb-8 text-4xl md:text-5xl text-red-500 uppercase;\r\n    }\r\n    h2 {\r\n        @apply mb-6 text-3xl md:text-4xl text-red-500;\r\n    }\r\n    h3 {\r\n        @apply mb-2 text-xl lg:text-2xl text-red-500;\r\n    }\r\n    section {\r\n        @apply max-w-7xl mx-auto text-center px-10 py-16;\r\n    }\r\n    a {\r\n        @apply capitalize;\r\n    }\r\n}\r\n\r\n@layer components {\r\n    .logo {\r\n        @apply w-48 h-14;\r\n    }\r\n    .icon-large {\r\n        @apply w-32 h-32;\r\n    }\r\n    .icon-medium {\r\n        @apply w-16 h-16;\r\n    }\r\n    .icon-small {\r\n        @apply w-6 h-6;\r\n    }\r\n\r\n    .btn {\r\n        @apply px-6 py-3 inline-block capitalize cursor-pointer font-semibold rounded-lg transition-all duration-300 hover:shadow-md hover:shadow-black/10 active:shadow-none;\r\n    }\r\n    .btn-primary {\r\n        @apply text-white bg-red-500  hover:opacity-80;\r\n    }\r\n    .btn-secondary {\r\n        @apply text-white bg-red-500  hover:opacity-80;\r\n    }\r\n    .btn-container {\r\n        @apply max-w-sm md:max-w-xl mx-auto flex flex-col md:flex-row justify-center items-center gap-2 text-xl;\r\n    }\r\n    .hover-link {\r\n        @apply hover:text-accentCyan transition-colors duration-300;\r\n    }\r\n\r\n    .background {\r\n        background-repeat: no-repeat;\r\n        background-size: cover;\r\n        background-position: center;\r\n    }\r\n    .body-background {\r\n        background-image: url(\"../images/bg-curvy-light-mode.svg\");\r\n    }\r\n    .dark .body-background {\r\n        background-image: url(\"../images/bg-curvy-dark-mode.svg\");\r\n        background-color: theme(colors.darkBlue);\r\n    }\r\n    .logo-background {\r\n        background-image: url(\"../images/logo-light-mode.svg\");\r\n    }\r\n    .dark .logo-background {\r\n        background-image: url(\"../images/logo-dark-mode.svg\");\r\n    }\r\n}\r\n"],"names":[],"version":3,"file":"fylo.748ad148.css.map","sourceRoot":"/__parcel_source_root/"}